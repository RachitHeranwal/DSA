class Solution {
    public int maxArea(int[] height) {
        int left = 0;
        int right = height.length - 1;
        int max = 0;

        while(left <= right){
            int tall = Math.min(height[left], height[right]);
            int width = right - left; 
            int area = tall*width;
            if(height[left] > height[right]){
                right--;
            }else {
                left++;
            }
            if(area > max){
            max = area;
            }
        }
        return max;
    }
}
